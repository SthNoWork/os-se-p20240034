#!/bin/bash

EXAM_DIR="$HOME/os-se-p20240034/final-exam"
BACKUP_DIR="$HOME/exam-backups"

timestamp=$(date '+%Y%m%d_%H%M%S')
archive_name="final-exam-${timestamp}.tar.gz"

mkdir -p "$BACKUP_DIR"
tar -czf "$BACKUP_DIR/$archive_name" -C "$(dirname "$EXAM_DIR")" "$(basename "$EXAM_DIR")"

echo "$(date '+%Y-%m-%d %H:%M:%S') | backup_exam created: $BACKUP_DIR/$archive_name"
