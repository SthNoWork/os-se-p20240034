#!/bin/bash

BASE_DIR="$HOME/os-se-p20240034/final-exam/partD_secure"
STOCK_FILE="$BASE_DIR/stock.txt"
SALES_LOG="$BASE_DIR/sales.log"
LOCK_FILE="$BASE_DIR/.stock.lock"
STUDENT_ID="p20240034"
MAX_PER_BUYER=5

buyer="$1"
qty="$2"

if [ -z "$buyer" ] || [ -z "$qty" ]; then
    echo "Usage: buy_reactor_core <buyer_name> <quantity>"
    exit 1
fi

if ! [[ "$qty" =~ ^[0-9]+$ ]] || [ "$qty" -le 0 ]; then
    echo "Error: quantity must be a positive integer"
    exit 1
fi

if [ "$qty" -gt "$MAX_PER_BUYER" ]; then
    echo "Error: order of $qty exceeds per-buyer cap of $MAX_PER_BUYER"
    exit 1
fi

if [ ! -f "$STOCK_FILE" ]; then
    echo 200 > "$STOCK_FILE"
fi

(
    flock -x 200

    stock=$(cat "$STOCK_FILE")

    if [ "$qty" -gt "$stock" ]; then
        echo "Error: not enough stock (have $stock, requested $qty)"
        exit 1
    fi

    new_stock=$((stock - qty))
    echo "$new_stock" > "$STOCK_FILE"

    echo "$(date '+%Y-%m-%d %H:%M:%S') | buyer=$buyer | qty=$qty | student=$STUDENT_ID | remaining=$new_stock" >> "$SALES_LOG"

    echo "Purchase successful: $buyer bought $qty Reactor Core(s). Remaining stock: $new_stock"

) 200>"$LOCK_FILE"
